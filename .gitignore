# Test fixtures (exclude binary test files)
tests/fixtures/*.gif
tests/fixtures/**/*.png
tests/fixtures/**/*.jpg
tests/fixtures/**/*.jpeg
tests/fixtures/phase3/

# Audit regression-guard fixtures: committed so the sanity harness has the
# transparency-bearing monotonicity base even when `make fixtures` has not
# been run.  Without this exception the sanity check would silently skip the
# PR #8 alpha-compositing guard on a fresh clone and report all PASS.
!tests/fixtures/transparency_bearing_monotonicity.gif

# Pipeline cache databases
pipeline_results_cache.db
**/pipeline_results_cache.db

# Test workspace - comprehensive exclusions
test-workspace/**/*.gif
test-workspace/**/*.csv
test-workspace/**/*.json
test-workspace/**/*.db
test-workspace/**/latest
test-workspace/**/run_*/
test-workspace/temp/
test-workspace/manual/*/
test-workspace/debug/*/
!test-workspace/manual/.gitkeep
!test-workspace/debug/.gitkeep
!test-workspace/temp/.gitkeep
!test-workspace/README.md

# Root directory testing pollution (should not exist, but just in case).
# Anchored to repo root with a leading `/` — without it, e.g. `deep_*`
# silently swallowed src/giflab/deep_perceptual_metrics.py, breaking the
# v0.3.0 release for external consumers (see fix in v0.3.1).
/debug_*
/final_*
/verification_*
/comprehensive_*
/deep_*
/gpu_*
/clean_test_*
*_test.gif
*test*.gif
/debug_*.png
/step*.gif
/pipeline_*.gif
*png_export*
*png_frames*
*png_sequence*
*png_from_*
*png_fix*

# Archives and documentation
docs/archive/
.claude/

# Serena MCP cache files
.serena/

# Database files
*.db
*.sqlite
*.sqlite3

# Additional experimental outputs (legacy)
elimination_results

# Benchmark results and performance analysis data
benchmark_results/

# Audit infrastructure — keep scripts/audit/, audit/sanity.json, audit/pilot.csv,
# audit/manifest.json, audit/pilot_decisions.json, and audit/README.md tracked.
# Exclude regeneratable / large artefacts. Both rules are anchored to the repo
# root with a leading slash for consistency (prevents accidental matches in any
# nested audit/ directory that might appear in tests/ or fixtures).
# NB: gitignore does NOT support inline trailing comments — keep comments on
# their own line. ".../foo.gif  # comment" treats the entire string as a literal
# pattern and silently fails to match.
# Generated GIF corpus — regenerate with scripts/audit/build_sample.py
/audit/synthetic/
# Derived sweep output — regenerate after each fix wave
/audit/sweep.csv

# One-off audit rerun scratch dirs (durable copies live under docs/metrics-audit/<date>/data/)
/audit-rerun-*/
